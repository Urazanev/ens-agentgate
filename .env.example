# --- HTTP server ---
PORT=3001
APP_DOMAIN=localhost:3001
APP_URI=http://localhost:3001

# --- Agent execution chain (where the wallet-native agent acts) ---
# Sepolia is the default for this MVP.
AGENT_CHAIN_ID=11155111
AGENT_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- ENS resolution (configurable, separate client) ---
# This MVP defaults to Sepolia ENS. Switch to mainnet (chainId=1) for production.
ENS_CHAIN_ID=11155111
ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional override for the ENS Universal Resolver address.
# Leave empty to use the viem default for the configured chain.
ENS_UNIVERSAL_RESOLVER_ADDRESS=

# --- Auth TTLs ---
CHALLENGE_TTL_SECONDS=300
SESSION_TTL_SECONDS=1800

# --- Logging ---
LOG_LEVEL=info

# --- Demo client (examples/demo-agent-client.ts) ---
# Private key compatible with viem privateKeyToAccount (same pattern used by onchain-agent).
# DEMO_ENS_NAME must resolve, on ENS_CHAIN_ID, to the address derived from DEMO_PRIVATE_KEY.
DEMO_PRIVATE_KEY=
DEMO_ENS_NAME=
AGENT_GATE_URL=http://localhost:3001
